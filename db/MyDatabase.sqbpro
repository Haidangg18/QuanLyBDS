-- =====================================
-- BẢNG 1: VAI_TRO
-- =====================================
CREATE TABLE VAI_TRO
(
    MaVaiTro INTEGER PRIMARY KEY AUTOINCREMENT,
    TenVaiTro VARCHAR(50) NOT NULL
);

-- =====================================
-- BẢNG 2: TAI_KHOAN
-- =====================================
CREATE TABLE TAI_KHOAN
(
    MaTaiKhoan INTEGER PRIMARY KEY AUTOINCREMENT,
    TenDangNhap VARCHAR(50) NOT NULL UNIQUE,
    MatKhau VARCHAR(255) NOT NULL,
    HoTen VARCHAR(100) NOT NULL,
    SoDienThoai VARCHAR(15),
    MaVaiTro INT NOT NULL,
    TrangThai TINYINT(1) DEFAULT 1,

    CONSTRAINT FK_TAIKHOAN_VAITRO
        FOREIGN KEY (MaVaiTro)
        REFERENCES VAI_TRO(MaVaiTro)
);

-- =====================================
-- BẢNG 3: LOAI_TAI_SAN
-- =====================================
CREATE TABLE LOAI_TAI_SAN
(
    MaLoaiTaiSan INTEGER PRIMARY KEY AUTOINCREMENT,
    TenLoaiTaiSan VARCHAR(50) NOT NULL
);

-- =====================================
-- BẢNG 4: TAI_SAN
-- =====================================
CREATE TABLE TAI_SAN
(
    MaTaiSan INTEGER PRIMARY KEY AUTOINCREMENT,
    MaLoaiTaiSan INT NOT NULL,
    MaSoTaiSan VARCHAR(20) NOT NULL UNIQUE,
    KhuVuc VARCHAR(100),
    DiaChi VARCHAR(255) NOT NULL,
    SoPhong VARCHAR(20),
    Tang INT,
    GiaThue DECIMAL(18,2) NOT NULL,
    HoaHong DECIMAL(18,2) DEFAULT 0.00,
    NgayTrong DATE,
    DaTungChoThue TINYINT(1) DEFAULT 0,
    TrangThai VARCHAR(50),
    NhanVienChotCu INT,
    HanThanhToan INT,
    ThietBi TEXT,
    GhiChu VARCHAR(500),
    MoTa TEXT,

    CONSTRAINT FK_TAISAN_LOAITAISAN
        FOREIGN KEY (MaLoaiTaiSan)
        REFERENCES LOAI_TAI_SAN(MaLoaiTaiSan),

    CONSTRAINT FK_TAISAN_NHANVIENCHOTCU
        FOREIGN KEY (NhanVienChotCu)
        REFERENCES TAI_KHOAN(MaTaiKhoan)
);

-- =====================================
-- BẢNG 5: KHACH_THUE
-- =====================================
CREATE TABLE KHACH_THUE
(
    MaKhachThue INTEGER PRIMARY KEY AUTOINCREMENT,
    HoTen VARCHAR(100) NOT NULL,
    SoDienThoai VARCHAR(15) NOT NULL,
    CCCD VARCHAR(20),
    NgaySinh DATE,
    DiaChiThuongTru VARCHAR(255),
    GhiChu VARCHAR(500)
);

-- =====================================
-- BẢNG 6: HOP_DONG
-- =====================================
CREATE TABLE HOP_DONG
(
    MaHopDong INTEGER PRIMARY KEY AUTOINCREMENT,
    MaTaiSan INT NOT NULL,
    MaKhachThue INT NOT NULL,
    NgayBatDau DATE NOT NULL,
    NgayKetThuc DATE NOT NULL,
    ThoiHanThue INT NOT NULL,
    TienCoc DECIMAL(18,2),
    TrangThai VARCHAR(50),
    GhiChu VARCHAR(500),

    CONSTRAINT FK_HOPDONG_TAISAN
        FOREIGN KEY (MaTaiSan)
        REFERENCES TAI_SAN(MaTaiSan),

    CONSTRAINT FK_HOPDONG_KHACHTHUE
        FOREIGN KEY (MaKhachThue)
        REFERENCES KHACH_THUE(MaKhachThue)
);

-- =====================================
-- BẢNG 7: CAU_HINH_GIA
-- =====================================
CREATE TABLE CAU_HINH_GIA
(
    MaCauHinh INTEGER PRIMARY KEY AUTOINCREMENT,
    GiaDien DECIMAL(18,2) NOT NULL,
    GiaDichVu DECIMAL(18,2) NOT NULL,
    NgayApDung DATE NOT NULL,
    TrangThai TINYINT(1) DEFAULT 1
);

-- =====================================
-- BẢNG 8: CHI_SO_DIEN
-- =====================================
CREATE TABLE CHI_SO_DIEN
(
    MaChiSo INTEGER PRIMARY KEY AUTOINCREMENT,
    MaTaiSan INT NOT NULL,
    Thang INT NOT NULL,
    Nam INT NOT NULL,
    ChiSoCu INT NOT NULL,
    ChiSoMoi INT NOT NULL,
    NgayNhap DATE NOT NULL,

    CONSTRAINT FK_CHISODIEN_TAISAN
        FOREIGN KEY (MaTaiSan)
        REFERENCES TAI_SAN(MaTaiSan)
);

-- =====================================
-- BẢNG 9: HOA_DON
-- =====================================
CREATE TABLE HOA_DON
(
    MaHoaDon INTEGER PRIMARY KEY AUTOINCREMENT,
    MaHopDong INT NOT NULL,
    Thang INT NOT NULL,
    Nam INT NOT NULL,
    TienNha DECIMAL(18,2) DEFAULT 0.00,
    SoDien INT DEFAULT 0,
    GiaDien DECIMAL(18,2) DEFAULT 0.00,
    TienDien DECIMAL(18,2) DEFAULT 0.00,
    GiaDichVu DECIMAL(18,2) DEFAULT 0.00,
    TienDichVu DECIMAL(18,2) DEFAULT 0.00,
    TongTien DECIMAL(18,2) DEFAULT 0.00,
    NgayTao DATE NOT NULL,
    TrangThaiThanhToan VARCHAR(50),

    CONSTRAINT FK_HOADON_HOPDONG
        FOREIGN KEY (MaHopDong)
        REFERENCES HOP_DONG(MaHopDong)
);

-- =====================================
-- BẢNG 10: THONG_TIN_CHOT_KHACH
-- =====================================
CREATE TABLE THONG_TIN_CHOT_KHACH
(
    MaChotKhach INTEGER PRIMARY KEY AUTOINCREMENT,
    MaTaiSan INT NOT NULL,
    MaTaiKhoanChot INT NOT NULL,
    TenKhach VARCHAR(100) NOT NULL,
    SoDienThoaiKhach VARCHAR(15) NOT NULL,
    CCCD VARCHAR(20),
    TienCoc DECIMAL(18,2),
    NgayChot DATE NOT NULL,
    NgayDuKienVaoO DATE,
    SoDienDauVao INT DEFAULT 0,
    TrangThai VARCHAR(50),
    MaKhachThue INT NULL,
    MaHopDong INT NULL,
    GhiChu VARCHAR(500),

    CONSTRAINT FK_CHOTKHACH_TAISAN
        FOREIGN KEY (MaTaiSan)
        REFERENCES TAI_SAN(MaTaiSan),

    CONSTRAINT FK_CHOTKHACH_TAIKHOAN
        FOREIGN KEY (MaTaiKhoanChot)
        REFERENCES TAI_KHOAN(MaTaiKhoan),

    CONSTRAINT FK_CHOTKHACH_KHACHTHUE
        FOREIGN KEY (MaKhachThue)
        REFERENCES KHACH_THUE(MaKhachThue),

    CONSTRAINT FK_CHOTKHACH_HOPDONG
        FOREIGN KEY (MaHopDong)
        REFERENCES HOP_DONG(MaHopDong)
);

-- =====================================
-- BẢNG 11: VAT_TU
-- =====================================
CREATE TABLE VAT_TU
(
    MaVatTu INTEGER PRIMARY KEY AUTOINCREMENT,
    TenVatTu VARCHAR(100) NOT NULL,
    DonViTinh VARCHAR(50),
    SoLuongTon INT DEFAULT 0,
    GhiChu VARCHAR(255)
);

-- =====================================
-- BẢNG 12: LICH_SU_KHO
-- =====================================
CREATE TABLE LICH_SU_KHO
(
    MaLichSu INTEGER PRIMARY KEY AUTOINCREMENT,
    MaVatTu INT NOT NULL,
    LoaiGiaoDich VARCHAR(20) NOT NULL,
    SoLuong INT NOT NULL,
    NgayGiaoDich DATE NOT NULL,
    NoiDung VARCHAR(255),
    MaTaiSan INT,

    CONSTRAINT FK_LICHSUKHO_VATTU
        FOREIGN KEY (MaVatTu)
        REFERENCES VAT_TU(MaVatTu),

    CONSTRAINT FK_LICHSUKHO_TAISAN
        FOREIGN KEY (MaTaiSan)
        REFERENCES TAI_SAN(MaTaiSan)
);


